@{
  var activePage = (ViewData["ActivePage"] as string ?? string.Empty).Trim();
  var isHome = string.Equals(activePage, "Home", StringComparison.OrdinalIgnoreCase);
  var isComidas = string.Equals(activePage, "Comidas", StringComparison.OrdinalIgnoreCase);
  var isIANutri = string.Equals(activePage, "IANutri", StringComparison.OrdinalIgnoreCase);
}
<div class="navbar">
  <div class="navbar-main">
    <div class="logo">Food DNA</div>
    <ul class="nav-links">
      <li>
        <a asp-controller="Home" asp-action="Home" asp-fragment="welcome-section" data-section="welcome-section" class="nav-btn@(isHome ? " active" : "")">Home</a>
      </li>
      <li>
        <a asp-controller="Home" asp-action="Home" asp-fragment="scanner-section" data-section="scanner-section" class="nav-btn">Escanear producto</a>
      </li>
      <li>
        <a asp-controller="Home" asp-action="Comidas" class="@(isComidas ? "active" : string.Empty)">Comidas</a>
      </li>
      <li>
        <a asp-controller="Home" asp-action="IANutri" class="@(isIANutri ? "active" : string.Empty)">IANutri</a>
      </li>
    </ul>
  </div>

  <div class="user-menu" data-user-menu>
    <button type="button" class="user-menu-trigger" data-user-menu-trigger aria-haspopup="true" aria-expanded="false" aria-label="Abrir menu de usuario">
      <span class="user-avatar" data-user-avatar>U</span>
      <span class="user-meta">
        <span class="user-name" data-user-name>Tu cuenta</span>
        <span class="user-email" data-user-email>inicia sesion</span>
      </span>
      <span class="user-chevron" aria-hidden="true"></span>
    </button>

    <div class="user-menu-panel" data-user-menu-panel role="menu" aria-hidden="true">
      <a asp-controller="Home" asp-action="Home" asp-fragment="config-section" data-section="config-section" data-user-menu-link class="user-menu-link nav-btn" role="menuitem">Gestionar alergenos</a>
      <a asp-controller="Home" asp-action="Home" asp-fragment="historial-section" data-section="historial-section" data-user-menu-link class="user-menu-link nav-btn" role="menuitem">Historial</a>
      <a asp-controller="Home" asp-action="Home" asp-fragment="contact-section" data-section="contact-section" data-user-menu-link class="user-menu-link nav-btn" role="menuitem">Soporte</a>
      <a asp-controller="Home" asp-action="Index" data-user-menu-link data-user-logout class="user-menu-link user-menu-link-danger" role="menuitem">Cerrar sesion</a>
    </div>
  </div>
</div>
<script src="/src/ventanas/navbar.js"></script>
