# SafeByte backend environment variables (ASP.NET Core)
# Required for production
FIRESTORE__PROJECTID=your-gcp-project-id
GITHUB_MODELS_API_KEY=your-github-models-key
# Alternative compatibility key (if you use classic PAT)
GITHUB_TOKEN=

# Firebase service account as a single JSON string (recommended for Render/Railway/Azure)
# Example:
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"your-gcp-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
FIREBASE_CREDENTIALS=

# Optional
ASPNETCORE_ENVIRONMENT=Production
PORT=8080
CORS_ALLOWED_ORIGINS=https://your-service.onrender.com,http://localhost:5188
IANUTRI_API_KEY=
OPENAI_API_KEY=
