{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Firestore": {
    "CredentialsPath": "secrets/service-account.json",
    "SeedOnStartup": false
  },
  "IANutri": {
    "BaseUrl": "https://models.inference.ai.azure.com",
    "ApiKey": "${GITHUB_TOKEN}",
    "ReformulationModel": "gpt-4.1-nano",
    "SuggestionModel": "gpt-4.1",
    "CookingAssistantModel": "gpt-4.1",
    "TimeoutSeconds": 60
  }
}
